# ============================================================================
# ARMD-AI backend :: variables de entorno (copiar a backend/.env)
# Todas tienen valores por defecto en app/config.py; sobreescribe lo necesario.
# ============================================================================

# --- PostgreSQL: opcion A (campos individuales) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=armd_ai
DB_USER=postgres
DB_PASSWORD=postgres

# --- PostgreSQL: opcion B (una sola URL; tiene prioridad si se define) ---
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/armd_ai

# --- HTTP / CORS ---
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
# Origenes CORS permitidos, separados por coma (por defecto = FRONTEND_URL)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
